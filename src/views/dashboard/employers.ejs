<% locals.pageTitle = 'Senarai Majikan Kerajaan' %>

<div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
  <div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Senarai Majikan Kerajaan</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-dark-400">AI Validator akan semak nama majikan dari senarai ini</p>
  </div>
  <div class="flex gap-2">
    <button onclick="document.getElementById('pdfModal').classList.remove('hidden')"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-green-300 dark:border-green-600 text-sm font-medium text-green-700 dark:text-green-300 hover:bg-green-50 dark:hover:bg-green-900/20 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
      Upload PDF
    </button>
    <button onclick="document.getElementById('bulkModal').classList.remove('hidden')"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 text-sm font-medium text-gray-700 dark:text-dark-300 hover:bg-gray-50 dark:hover:bg-dark-700 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
      Import Senarai
    </button>
    <button onclick="document.getElementById('empModal').classList.remove('hidden')"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-primary-600 text-white text-sm font-medium hover:bg-primary-700 shadow-lg shadow-primary-500/25 transition-all">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Tambah Majikan
    </button>
  </div>
</div>

<!-- Filter Tabs -->
<div class="mb-4 flex flex-col sm:flex-row sm:items-center gap-3">
  <div class="flex gap-1 bg-gray-100 dark:bg-dark-700 rounded-xl p-1">
    <a href="?filter=all<%= search ? '&search=' + search : '' %>" 
       class="px-4 py-2 rounded-lg text-sm font-medium transition-colors <%= filter === 'all' ? 'bg-white dark:bg-dark-600 text-gray-900 dark:text-white shadow-sm' : 'text-gray-500 dark:text-dark-400 hover:text-gray-700' %>">
      Semua <span class="ml-1 text-xs opacity-60"><%= eligibleCount + notEligibleCount %></span>
    </a>
    <a href="?filter=eligible<%= search ? '&search=' + search : '' %>" 
       class="px-4 py-2 rounded-lg text-sm font-medium transition-colors <%= filter === 'eligible' ? 'bg-green-500 text-white shadow-sm' : 'text-gray-500 dark:text-dark-400 hover:text-gray-700' %>">
      ✅ Eligible <span class="ml-1 text-xs opacity-60"><%= eligibleCount %></span>
    </a>
    <a href="?filter=not-eligible<%= search ? '&search=' + search : '' %>" 
       class="px-4 py-2 rounded-lg text-sm font-medium transition-colors <%= filter === 'not-eligible' ? 'bg-red-500 text-white shadow-sm' : 'text-gray-500 dark:text-dark-400 hover:text-gray-700' %>">
      ❌ Not Eligible <span class="ml-1 text-xs opacity-60"><%= notEligibleCount %></span>
    </a>
  </div>
  <form action="/dashboard/employers" method="GET" class="flex gap-2 flex-1 sm:flex-none">
    <input type="hidden" name="filter" value="<%= filter %>">
    <input type="text" name="search" value="<%= search %>" placeholder="🔍 Cari majikan..." 
           class="w-full sm:w-64 px-4 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent">
    <button type="submit" class="px-4 py-2.5 rounded-xl bg-gray-100 dark:bg-dark-700 text-sm font-medium text-gray-700 dark:text-dark-300 hover:bg-gray-200 dark:hover:bg-dark-600 transition-colors">Cari</button>
    <% if (search) { %>
      <a href="?filter=<%= filter %>" class="px-3 py-2.5 rounded-xl text-sm text-gray-400 hover:text-gray-600 transition-colors">✕</a>
    <% } %>
  </form>
</div>

<!-- Employers Table -->
<div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-gray-200 dark:border-dark-700 bg-gray-50 dark:bg-dark-800">
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 dark:text-dark-400 uppercase tracking-wider">Nama Agensi</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 dark:text-dark-400 uppercase tracking-wider hidden md:table-cell">Kod</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 dark:text-dark-400 uppercase tracking-wider hidden md:table-cell">Sektor</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 dark:text-dark-400 uppercase tracking-wider hidden md:table-cell">Potongan</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 dark:text-dark-400 uppercase tracking-wider hidden lg:table-cell">Kategori</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 dark:text-dark-400 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 dark:text-dark-400 uppercase tracking-wider">Tindakan</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-dark-700">
        <% if (employers.length === 0) { %>
          <tr><td colspan="8" class="px-6 py-12 text-center text-sm text-gray-400 dark:text-dark-500">Tiada majikan dijumpai</td></tr>
        <% } %>
        <% employers.forEach(emp => { %>
          <tr class="hover:bg-gray-50 dark:hover:bg-dark-700/50 transition-colors">
            <td class="px-6 py-3">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center text-white text-xs font-bold"><%= emp.name.charAt(0) %></div>
                <span class="text-sm font-medium text-gray-900 dark:text-white"><%= emp.name %></span>
              </div>
            </td>
            <td class="px-6 py-3 text-sm text-gray-500 dark:text-dark-400 font-mono hidden md:table-cell"><%= emp.code || '-' %></td>
            <td class="px-6 py-3 hidden md:table-cell">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium
                <% if (emp.sector === 'AG') { %>bg-blue-50 text-blue-700 dark:bg-blue-500/10 dark:text-blue-400
                <% } else if (emp.sector === 'GLC') { %>bg-purple-50 text-purple-700 dark:bg-purple-500/10 dark:text-purple-400
                <% } else if (emp.sector === 'PDRM') { %>bg-orange-50 text-orange-700 dark:bg-orange-500/10 dark:text-orange-400
                <% } else { %>bg-gray-100 text-gray-600 dark:bg-dark-700 dark:text-dark-400<% } %>
              "><%= emp.sector || '-' %></span>
            </td>
            <td class="px-6 py-3 text-sm text-gray-500 dark:text-dark-400 font-mono hidden md:table-cell"><%= emp.deduction ? emp.deduction + '%' : '-' %></td>
            <td class="px-6 py-3 hidden lg:table-cell">
              <% if (emp.category) { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium 
                  <% if (emp.category === 'PERSEKUTUAN') { %>bg-blue-50 text-blue-700 dark:bg-blue-500/10 dark:text-blue-400
                  <% } else if (emp.category === 'NEGERI') { %>bg-purple-50 text-purple-700 dark:bg-purple-500/10 dark:text-purple-400
                  <% } else { %>bg-orange-50 text-orange-700 dark:bg-orange-500/10 dark:text-orange-400<% } %>
                "><%= emp.category %></span>
              <% } else { %>-<% } %>
            </td>
            <td class="px-6 py-3">
              <button onclick="toggleEmployer(<%= emp.id %>)" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-medium cursor-pointer transition-colors
                <%= emp.isApproved ? 'bg-green-50 text-green-700 dark:bg-green-500/10 dark:text-green-400 hover:bg-green-100' : 'bg-gray-100 text-gray-600 dark:bg-dark-700 dark:text-dark-400 hover:bg-gray-200' %>">
                <span class="w-1.5 h-1.5 rounded-full <%= emp.isApproved ? 'bg-green-500' : 'bg-gray-400' %>"></span>
                <%= emp.isApproved ? 'Diluluskan' : 'Tidak Aktif' %>
              </button>
            </td>
            <td class="px-6 py-3 text-right">
              <button onclick="deleteEmployer(<%= emp.id %>)" class="p-1.5 rounded-lg text-gray-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% if (totalPages > 1) { %>
    <% const qs = '&filter=' + filter + (search ? '&search=' + search : ''); %>
    <div class="px-6 py-3 border-t border-gray-200 dark:border-dark-700 flex items-center justify-between">
      <p class="text-xs text-gray-500 dark:text-dark-400">Halaman <%= page %> dari <%= totalPages %> (<%= total %> rekod)</p>
      <div class="flex gap-2">
        <% if (page > 1) { %><a href="?page=<%= page - 1 %><%= qs %>" class="px-3 py-1.5 rounded-lg text-xs font-medium bg-gray-100 dark:bg-dark-700 hover:bg-gray-200 dark:hover:bg-dark-600 transition-colors">Sebelum</a><% } %>
        <% if (page < totalPages) { %><a href="?page=<%= page + 1 %><%= qs %>" class="px-3 py-1.5 rounded-lg text-xs font-medium bg-gray-100 dark:bg-dark-700 hover:bg-gray-200 dark:hover:bg-dark-600 transition-colors">Seterusnya</a><% } %>
      </div>
    </div>
  <% } %>
</div>

<!-- Create Modal -->
<div id="empModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/50" onclick="this.parentElement.classList.add('hidden')"></div>
  <div class="relative bg-white dark:bg-dark-800 rounded-2xl p-6 w-full max-w-md shadow-2xl border border-gray-200 dark:border-dark-700">
    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-5">Tambah Majikan Baru</h3>
    <form id="empForm" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Nama Agensi *</label>
        <input type="text" name="name" required placeholder="cth: Jabatan Perdana Menteri" class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent">
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Kod</label>
          <input type="text" name="code" placeholder="cth: JPM" class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent font-mono uppercase">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Sektor</label>
          <select name="sector" class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500">
            <option value="AG">AG</option>
            <option value="GLC">GLC</option>
            <option value="PDRM">PDRM</option>
          </select>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Kategori</label>
          <select name="category" class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500">
            <option value="PERSEKUTUAN">Persekutuan</option>
            <option value="NEGERI">Negeri</option>
            <option value="PBT">PBT</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Potongan %</label>
          <input type="number" name="deduction" value="60" min="0" max="100" class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent font-mono">
        </div>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="button" onclick="document.getElementById('empModal').classList.add('hidden')" class="flex-1 px-4 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 text-sm font-medium text-gray-700 dark:text-dark-300 hover:bg-gray-50 dark:hover:bg-dark-700 transition-colors">Batal</button>
        <button type="submit" class="flex-1 px-4 py-2.5 rounded-xl bg-primary-600 text-white text-sm font-medium hover:bg-primary-700 shadow-lg shadow-primary-500/25 transition-all">Simpan</button>
      </div>
    </form>
  </div>
</div>

<script>

document.getElementById('empForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = new FormData(e.target);
  const data = Object.fromEntries(form);
  try {
    const res = await fetch('/api/employers', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    const result = await res.json();
    if (result.success) location.reload();
    else alert(result.error || 'Gagal');
  } catch (err) { alert('Error'); }
});

async function toggleEmployer(id) {
  try {
    await fetch(`/api/employers/${id}/toggle`, { method: 'PATCH' });
    location.reload();
  } catch (err) { alert('Error'); }
}

async function deleteEmployer(id) {
  if (!confirm('Padam majikan ini?')) return;
  try {
    await fetch(`/api/employers/${id}`, { method: 'DELETE' });
    location.reload();
  } catch (err) { alert('Error'); }
}

function filterTable(q) {
  const rows = document.querySelectorAll('tbody tr');
  const query = q.toLowerCase();
  rows.forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(query) ? '' : 'none';
  });
}

async function bulkImport() {
  const text = document.getElementById('bulkText').value.trim();
  if (!text) return alert('Sila masukkan senarai');
  
  const category = document.getElementById('bulkCategory').value;
  const sector = document.getElementById('bulkSector').value;
  const deduction = document.getElementById('bulkDeduction').value;
  const isApproved = document.getElementById('bulkApproved').value === 'true';
  const lines = text.split('\n').map(l => l.trim()).filter(l => l.length > 0);
  
  if (lines.length === 0) return alert('Senarai kosong');
  if (!confirm(`Import ${lines.length} majikan sebagai ${isApproved ? 'ELIGIBLE' : 'NOT ELIGIBLE'}?`)) return;
  
  const btn = document.getElementById('bulkBtn');
  const progress = document.getElementById('bulkProgress');
  btn.disabled = true;
  btn.textContent = 'Mengimport...';
  
  let success = 0, failed = 0;
  for (let i = 0; i < lines.length; i++) {
    try {
      const res = await fetch('/api/employers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: lines[i], category, sector, deduction: parseInt(deduction), isApproved }),
      });
      const result = await res.json();
      if (result.success) success++;
      else failed++;
    } catch { failed++; }
    progress.textContent = `${i + 1}/${lines.length} (✓${success} ✗${failed})`;
  }
  
  alert(`Selesai! Berjaya: ${success}, Gagal: ${failed}`);
  location.reload();
}
</script>

<!-- Bulk Import Modal -->
<div id="bulkModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/50" onclick="this.parentElement.classList.add('hidden')"></div>
  <div class="relative bg-white dark:bg-dark-800 rounded-2xl p-6 w-full max-w-lg shadow-2xl border border-gray-200 dark:border-dark-700">
    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Import Senarai Majikan</h3>
    <p class="text-xs text-gray-500 dark:text-dark-400 mb-4">Masukkan satu nama majikan setiap baris. Boleh copy-paste dari Excel atau Word.</p>
    
    <div class="grid grid-cols-2 gap-3 mb-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Sektor</label>
        <select id="bulkSector" class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500">
          <option value="AG">AG (Agensi Kerajaan)</option>
          <option value="GLC">GLC</option>
          <option value="PDRM">PDRM</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Potongan %</label>
        <select id="bulkDeduction" class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500">
          <option value="60">60%</option>
          <option value="50">50%</option>
          <option value="40">40%</option>
        </select>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-3 mb-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Kategori</label>
        <select id="bulkCategory" class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500">
          <option value="PERSEKUTUAN">Persekutuan</option>
          <option value="NEGERI">Negeri</option>
          <option value="PBT">PBT</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Status</label>
        <select id="bulkApproved" class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500">
          <option value="true">✅ Eligible (Diluluskan)</option>
          <option value="false">❌ Not Eligible (Tidak Diluluskan)</option>
        </select>
      </div>
    </div>
    
    <textarea id="bulkText" rows="12" placeholder="Jabatan Perdana Menteri&#10;Kementerian Kewangan&#10;Hospital Kuala Lumpur&#10;..." 
              class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent font-mono mb-4"></textarea>
    
    <div class="flex items-center justify-between">
      <span id="bulkProgress" class="text-xs text-gray-400 dark:text-dark-500"></span>
      <div class="flex gap-3">
        <button type="button" onclick="document.getElementById('bulkModal').classList.add('hidden')" class="px-4 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 text-sm font-medium text-gray-700 dark:text-dark-300 hover:bg-gray-50 dark:hover:bg-dark-700 transition-colors">Batal</button>
        <button type="button" id="bulkBtn" onclick="bulkImport()" class="px-4 py-2.5 rounded-xl bg-primary-600 text-white text-sm font-medium hover:bg-primary-700 shadow-lg shadow-primary-500/25 transition-all">Import</button>
      </div>
    </div>
  </div>
</div>

<!-- PDF Upload Modal -->
<div id="pdfModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/50" onclick="this.parentElement.classList.add('hidden')"></div>
  <div class="relative bg-white dark:bg-dark-800 rounded-2xl p-6 w-full max-w-lg shadow-2xl border border-gray-200 dark:border-dark-700">
    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Upload PDF Senarai Majikan</h3>
    <p class="text-xs text-gray-500 dark:text-dark-400 mb-4">Upload PDF format seperti "WM ELIGIBLE.pdf". Sistem akan parse nama, sektor, potongan & auto-assign kod agensi.</p>
    
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Status</label>
      <select id="pdfApproved" class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500">
        <option value="true">✅ Eligible (Diluluskan)</option>
        <option value="false">❌ Not Eligible (Tidak Diluluskan)</option>
      </select>
    </div>

    <div id="pdfDropzone" class="mb-4 border-2 border-dashed border-gray-300 dark:border-dark-600 rounded-xl p-8 text-center cursor-pointer hover:border-primary-400 dark:hover:border-primary-500 transition-colors"
         onclick="document.getElementById('pdfFile').click()"
         ondrop="handleDrop(event)" ondragover="event.preventDefault(); this.classList.add('border-primary-500')" ondragleave="this.classList.remove('border-primary-500')">
      <svg class="w-10 h-10 mx-auto text-gray-300 dark:text-dark-500 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
      <p class="text-sm text-gray-500 dark:text-dark-400" id="pdfFileName">Klik atau seret PDF ke sini</p>
      <p class="text-xs text-gray-400 dark:text-dark-500 mt-1">Maksimum 20MB</p>
      <input type="file" id="pdfFile" accept=".pdf" class="hidden" onchange="handleFileSelect(this)">
    </div>
    
    <div class="flex items-center justify-between">
      <span id="pdfProgress" class="text-xs text-gray-400 dark:text-dark-500"></span>
      <div class="flex gap-3">
        <button type="button" onclick="document.getElementById('pdfModal').classList.add('hidden')" class="px-4 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 text-sm font-medium text-gray-700 dark:text-dark-300 hover:bg-gray-50 dark:hover:bg-dark-700 transition-colors">Batal</button>
        <button type="button" id="pdfBtn" onclick="uploadPdf()" disabled class="px-4 py-2.5 rounded-xl bg-green-600 text-white text-sm font-medium hover:bg-green-700 shadow-lg shadow-green-500/25 transition-all disabled:opacity-50 disabled:cursor-not-allowed">Upload & Import</button>
      </div>
    </div>
  </div>
</div>

<script>
let selectedPdfFile = null;

function handleFileSelect(input) {
  if (input.files[0]) {
    selectedPdfFile = input.files[0];
    document.getElementById('pdfFileName').textContent = selectedPdfFile.name + ' (' + (selectedPdfFile.size / 1024 / 1024).toFixed(1) + ' MB)';
    document.getElementById('pdfBtn').disabled = false;
    document.getElementById('pdfDropzone').classList.add('border-green-400', 'dark:border-green-500');
  }
}

function handleDrop(e) {
  e.preventDefault();
  const file = e.dataTransfer.files[0];
  if (file && file.type === 'application/pdf') {
    selectedPdfFile = file;
    document.getElementById('pdfFileName').textContent = file.name + ' (' + (file.size / 1024 / 1024).toFixed(1) + ' MB)';
    document.getElementById('pdfBtn').disabled = false;
    document.getElementById('pdfDropzone').classList.add('border-green-400', 'dark:border-green-500');
  }
}

async function uploadPdf() {
  if (!selectedPdfFile) return;
  
  const btn = document.getElementById('pdfBtn');
  const progress = document.getElementById('pdfProgress');
  btn.disabled = true;
  btn.textContent = 'Memproses...';
  progress.textContent = 'Mengupload PDF...';

  const formData = new FormData();
  formData.append('pdf', selectedPdfFile);
  formData.append('isApproved', document.getElementById('pdfApproved').value);

  try {
    const res = await fetch('/api/employers/upload-pdf', { method: 'POST', body: formData });
    const result = await res.json();
    if (result.success) {
      alert(`Selesai!\n\nJumlah ditemui: ${result.total}\nBerjaya diimport: ${result.inserted}\nDuplicate/skip: ${result.skipped}`);
      location.reload();
    } else {
      alert('Gagal: ' + (result.error || 'Unknown error'));
      btn.textContent = 'Upload & Import';
      btn.disabled = false;
    }
  } catch (err) {
    alert('Error: ' + err.message);
    btn.textContent = 'Upload & Import';
    btn.disabled = false;
  }
}
</script>
