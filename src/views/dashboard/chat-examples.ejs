<% locals.pageTitle = 'Contoh Perbualan' %>

<div class="mb-6 flex items-center justify-between flex-wrap gap-4">
  <div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Contoh Perbualan</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-dark-400">Library balasan sebenar dari chat WhatsApp. AI rujuk contoh ini untuk balas dengan tepat.</p>
  </div>
  <div class="flex gap-2 flex-wrap">
    <button onclick="cleanAll()" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-amber-300 dark:border-amber-600 text-sm font-medium text-amber-700 dark:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
      Bersihkan
    </button>
    <button onclick="deleteAll()" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-red-300 dark:border-red-600 text-sm font-medium text-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-500/10 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
      Padam Semua
    </button>
    <button onclick="showUploadModal()" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-300 dark:border-dark-600 text-sm font-medium text-gray-700 dark:text-dark-300 hover:bg-gray-100 dark:hover:bg-dark-800 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
      Import Chat
    </button>
    <button onclick="showAddModal()" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-primary-600 text-white text-sm font-medium hover:bg-primary-700 shadow-lg shadow-primary-500/25 transition-all">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Tambah Manual
    </button>
  </div>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
  <div class="bg-white dark:bg-dark-800 rounded-xl border border-gray-200 dark:border-dark-700 p-4">
    <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= totalAll %></p>
    <p class="text-xs text-gray-500 dark:text-dark-400">Jumlah Contoh</p>
  </div>
  <div class="bg-white dark:bg-dark-800 rounded-xl border border-gray-200 dark:border-dark-700 p-4">
    <p class="text-2xl font-bold text-emerald-600"><%= totalActive %></p>
    <p class="text-xs text-gray-500 dark:text-dark-400">Aktif</p>
  </div>
  <div class="bg-white dark:bg-dark-800 rounded-xl border border-gray-200 dark:border-dark-700 p-4">
    <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= categories.length %></p>
    <p class="text-xs text-gray-500 dark:text-dark-400">Kategori</p>
  </div>
  <div class="bg-white dark:bg-dark-800 rounded-xl border border-gray-200 dark:border-dark-700 p-4">
    <p class="text-2xl font-bold text-gray-400"><%= totalAll - totalActive %></p>
    <p class="text-xs text-gray-500 dark:text-dark-400">Tidak Aktif</p>
  </div>
</div>

<!-- Category Filter -->
<div class="flex gap-2 mb-4 overflow-x-auto pb-1">
  <a href="/dashboard/chat-examples" class="px-3 py-1.5 rounded-lg text-xs font-medium whitespace-nowrap transition-colors <%= !activeCategory ? 'bg-primary-100 dark:bg-primary-500/10 text-primary-700 dark:text-primary-400' : 'bg-gray-100 dark:bg-dark-800 text-gray-600 dark:text-dark-300 hover:bg-gray-200 dark:hover:bg-dark-700' %>">Semua</a>
  <% categories.forEach(cat => { %>
    <a href="/dashboard/chat-examples?category=<%= cat %>" class="px-3 py-1.5 rounded-lg text-xs font-medium whitespace-nowrap transition-colors <%= activeCategory === cat ? 'bg-primary-100 dark:bg-primary-500/10 text-primary-700 dark:text-primary-400' : 'bg-gray-100 dark:bg-dark-800 text-gray-600 dark:text-dark-300 hover:bg-gray-200 dark:hover:bg-dark-700' %>"><%= cat %></a>
  <% }); %>
</div>

<!-- Examples List -->
<div class="space-y-3">
  <% if (examples.length === 0) { %>
    <div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 p-12 text-center">
      <svg class="w-12 h-12 mx-auto text-gray-300 dark:text-dark-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
      <p class="text-gray-500 dark:text-dark-400">Tiada contoh perbualan. Import chat WhatsApp atau tambah secara manual.</p>
    </div>
  <% } %>
  <% examples.forEach(ex => { %>
    <div class="bg-white dark:bg-dark-800 rounded-xl border border-gray-200 dark:border-dark-700 p-4 <%= !ex.active ? 'opacity-50' : '' %> hover:shadow-sm transition-shadow">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-2">
            <span class="px-2 py-0.5 rounded-md text-xs font-medium bg-blue-100 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400"><%= ex.category %></span>
            <% if (!ex.active) { %><span class="text-xs text-gray-400">tidak aktif</span><% } %>
          </div>
          <div class="space-y-1.5">
            <div class="flex gap-2">
              <span class="text-xs font-medium text-gray-400 dark:text-dark-500 mt-0.5 shrink-0">C:</span>
              <p class="text-sm text-gray-700 dark:text-dark-300"><%= ex.customerMessage %></p>
            </div>
            <div class="flex gap-2">
              <span class="text-xs font-medium text-emerald-500 mt-0.5 shrink-0">A:</span>
              <p class="text-sm text-gray-900 dark:text-white"><%= ex.adminReply %></p>
            </div>
          </div>
        </div>
        <div class="flex items-center gap-1 shrink-0">
          <button onclick="toggleExample(<%= ex.id %>)" class="p-1.5 rounded-lg text-gray-400 hover:text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-500/10 transition-colors" title="<%= ex.active ? 'Nyahaktif' : 'Aktifkan' %>">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= ex.active ? 'M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636' : 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' %>"/></svg>
          </button>
          <button onclick="deleteExample(<%= ex.id %>)" class="p-1.5 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-500/10 transition-colors" title="Padam">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          </button>
        </div>
      </div>
    </div>
  <% }); %>
</div>

<% if (totalPages > 1) { %>
<div class="mt-4 flex items-center justify-center gap-2">
  <% if (page > 1) { %>
    <a href="/dashboard/chat-examples?page=<%= page - 1 %><%= activeCategory ? '&category=' + activeCategory : '' %>" class="px-3 py-1.5 rounded-lg text-sm bg-gray-100 dark:bg-dark-800 text-gray-700 dark:text-dark-300 hover:bg-gray-200 dark:hover:bg-dark-700">← Sebelum</a>
  <% } %>
  <span class="text-sm text-gray-500 dark:text-dark-400">Muka <strong><%= page %></strong> dari <strong><%= totalPages %></strong> (<%= total %> contoh)</span>
  <% if (page < totalPages) { %>
    <a href="/dashboard/chat-examples?page=<%= page + 1 %><%= activeCategory ? '&category=' + activeCategory : '' %>" class="px-3 py-1.5 rounded-lg text-sm bg-gray-100 dark:bg-dark-800 text-gray-700 dark:text-dark-300 hover:bg-gray-200 dark:hover:bg-dark-700">Seterusnya →</a>
  <% } %>
</div>
<% } %>

<!-- Upload Results (shown after import) -->
<div id="uploadResults" class="hidden mt-4 bg-white dark:bg-dark-800 rounded-xl border border-gray-200 dark:border-dark-700 p-4">
  <h4 class="text-sm font-semibold text-gray-900 dark:text-white mb-2">Keputusan Import</h4>
  <div id="uploadResultContent" class="text-sm space-y-1"></div>
</div>



<!-- Upload Modal -->
<div id="uploadModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
  <div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-xl p-6 w-full max-w-md mx-4">
    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Import Chat WhatsApp</h3>
    <p class="text-xs text-gray-500 dark:text-dark-400 mb-4">Export chat dari WhatsApp (Without Media) dan muat naik fail .txt. Boleh pilih <strong>beberapa fail sekaligus</strong>.</p>
    <form id="uploadForm" enctype="multipart/form-data">
      <input type="file" name="chatFile" accept=".txt" multiple required class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white file:mr-3 file:py-1 file:px-3 file:rounded-lg file:border-0 file:bg-primary-50 file:text-primary-700 file:text-xs file:font-medium dark:file:bg-primary-500/10 dark:file:text-primary-400" id="chatFileInput">
      <p id="fileCount" class="mt-1.5 text-xs text-gray-400 dark:text-dark-500"></p>
      <div id="uploadProgress" class="hidden mt-3 p-3 rounded-xl bg-blue-50 dark:bg-blue-500/10 text-sm text-blue-700 dark:text-blue-400"></div>
      <div class="flex justify-end gap-3 mt-4">
        <button type="button" onclick="closeModal('uploadModal')" class="px-4 py-2 rounded-xl border border-gray-300 dark:border-dark-600 text-sm font-medium text-gray-700 dark:text-dark-300 hover:bg-gray-100 dark:hover:bg-dark-700">Batal</button>
        <button type="submit" id="uploadBtn" class="px-4 py-2 rounded-xl bg-primary-600 text-white text-sm font-medium hover:bg-primary-700">Import</button>
      </div>
    </form>
  </div>
</div>

<!-- Add Manual Modal -->
<div id="addModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
  <div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-xl p-6 w-full max-w-md mx-4">
    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Tambah Contoh</h3>
    <form id="addForm" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Kategori</label>
        <select name="category" required class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white">
          <option value="greeting">greeting</option>
          <option value="scam_defense">scam_defense</option>
          <option value="employer_check">employer_check</option>
          <option value="eligible">eligible</option>
          <option value="not_eligible">not_eligible</option>
          <option value="product_info">product_info</option>
          <option value="escalation">escalation</option>
          <option value="follow_up">follow_up</option>
          <option value="general">general</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Mesej Pelanggan</label>
        <textarea name="customerMessage" rows="2" required class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white" placeholder="contoh: pm"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Balasan Admin</label>
        <textarea name="adminReply" rows="3" required class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white" placeholder="contoh: Salam tuan/puan..."></textarea>
      </div>
      <div class="flex justify-end gap-3">
        <button type="button" onclick="closeModal('addModal')" class="px-4 py-2 rounded-xl border border-gray-300 dark:border-dark-600 text-sm font-medium text-gray-700 dark:text-dark-300">Batal</button>
        <button type="submit" class="px-4 py-2 rounded-xl bg-primary-600 text-white text-sm font-medium hover:bg-primary-700">Simpan</button>
      </div>
    </form>
  </div>
</div>

<script>
function showUploadModal() { document.getElementById('uploadModal').classList.remove('hidden'); document.getElementById('uploadModal').classList.add('flex'); }
function showAddModal() { document.getElementById('addModal').classList.remove('hidden'); document.getElementById('addModal').classList.add('flex'); }
function closeModal(id) { document.getElementById(id).classList.add('hidden'); document.getElementById(id).classList.remove('flex'); }

document.getElementById('chatFileInput').addEventListener('change', (e) => {
  const n = e.target.files.length;
  document.getElementById('fileCount').textContent = n > 0 ? `${n} fail dipilih` : '';
});

document.getElementById('uploadForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = document.getElementById('uploadBtn');
  const progress = document.getElementById('uploadProgress');
  const files = document.getElementById('chatFileInput').files;
  btn.textContent = `Memproses ${files.length} fail...`; btn.disabled = true;
  progress.textContent = 'AI sedang membaca dan mengkategorikan chat...';
  progress.classList.remove('hidden');
  const form = new FormData(e.target);
  try {
    const res = await fetch('/dashboard/chat-examples/upload', { method: 'POST', body: form });
    const result = await res.json();
    if (result.success) {
      closeModal('uploadModal');
      const resultsDiv = document.getElementById('uploadResults');
      const content = document.getElementById('uploadResultContent');
      let html = `<p class="text-emerald-600">✅ Berjaya import <strong>${result.count}</strong> contoh dari <strong>${result.files}</strong> fail.</p>`;
      if (result.errors && result.errors.length) {
        html += '<p class="text-red-500 mt-2">❌ Gagal:</p><ul class="list-disc pl-5 text-red-500">';
        result.errors.forEach(e => html += `<li>${e}</li>`);
        html += '</ul>';
      }
      html += '<p class="mt-2"><a href="/dashboard/chat-examples" class="text-primary-600 hover:underline">Muat semula untuk lihat contoh →</a></p>';
      content.innerHTML = html;
      resultsDiv.classList.remove('hidden');
      btn.textContent = 'Import'; btn.disabled = false;
      progress.classList.add('hidden');
    } else {
      alert(result.error || 'Gagal');
      btn.textContent = 'Import'; btn.disabled = false;
      progress.classList.add('hidden');
    }
  } catch (err) {
    alert('Error');
    btn.textContent = 'Import'; btn.disabled = false;
    progress.classList.add('hidden');
  }
});

document.getElementById('addForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const data = Object.fromEntries(new FormData(e.target));
  try {
    const res = await fetch('/dashboard/chat-examples', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(data) });
    const result = await res.json();
    if (result.success) location.reload();
    else alert(result.error);
  } catch (err) { alert('Error'); }
});

async function toggleExample(id) {
  try { const res = await fetch(`/dashboard/chat-examples/${id}/toggle`, { method: 'POST' }); if ((await res.json()).success) location.reload(); } catch(e) { alert('Error'); }
}
async function deleteExample(id) {
  if (!confirm('Padam contoh ini?')) return;
  try { const res = await fetch(`/dashboard/chat-examples/${id}`, { method: 'DELETE' }); if ((await res.json()).success) location.reload(); } catch(e) { alert('Error'); }
}
async function deleteAll() {
  if (!confirm('Padam SEMUA contoh perbualan?')) return;
  try { const res = await fetch('/dashboard/chat-examples/all', { method: 'DELETE' }); if ((await res.json()).success) location.reload(); } catch(e) { alert('Error'); }
}
async function cleanAll() {
  try {
    const res = await fetch('/dashboard/chat-examples/clean', { method: 'POST' });
    const result = await res.json();
    if (result.success) { alert(`Berjaya bersihkan ${result.cleaned} contoh.`); location.reload(); }
    else alert(result.error);
  } catch(e) { alert('Error'); }
}
</script>
