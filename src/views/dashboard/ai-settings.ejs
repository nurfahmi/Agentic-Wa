<% locals.pageTitle = 'AI Knowledge' %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">AI Knowledge</h1>
  <p class="mt-1 text-sm text-gray-500 dark:text-dark-400">Urus pengetahuan dan tingkah laku AI agent. Semua maklumat boleh dikemaskini tanpa perlu ubah kod.</p>
</div>

<form id="aiSettingsForm" class="max-w-4xl">
  <!-- Tabs -->
  <div class="flex gap-1 mb-6 bg-gray-100 dark:bg-dark-800 rounded-xl p-1 overflow-x-auto">
    <button type="button" data-tab="identity" class="tab-btn active flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium whitespace-nowrap transition-all">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      Identiti
    </button>
    <button type="button" data-tab="knowledge" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium whitespace-nowrap transition-all">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
      Pengetahuan
    </button>
    <button type="button" data-tab="messages" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium whitespace-nowrap transition-all">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
      Contoh Mesej
    </button>
    <button type="button" data-tab="escalation" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium whitespace-nowrap transition-all">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
      Eskalasi
    </button>
    <button type="button" data-tab="manual" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium whitespace-nowrap transition-all">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
      Manual Reply
    </button>
  </div>

  <!-- Tab: Identity -->
  <div id="tab-identity" class="tab-content">
    <div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-dark-700 bg-gray-50 dark:bg-dark-900/50">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Identiti Agent</h3>
        <p class="mt-0.5 text-xs text-gray-500 dark:text-dark-400">Maklumat asas pegawai AI yang berinteraksi dengan pelanggan.</p>
      </div>
      <div class="p-6 space-y-5">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1.5">Nama Pegawai</label>
            <input type="text" name="ai_agent_name" value="<%= settings.ai_agent_name || defaults.ai_agent_name %>" class="w-full px-3.5 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow">
            <p class="mt-1.5 text-xs text-gray-400 dark:text-dark-500">Nama yang AI gunakan, contoh: Puan Sarah</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1.5">Nama Koperasi</label>
            <input type="text" name="ai_koperasi_name" value="<%= settings.ai_koperasi_name || defaults.ai_koperasi_name %>" class="w-full px-3.5 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow">
            <p class="mt-1.5 text-xs text-gray-400 dark:text-dark-500">Nama organisasi yang AI wakili</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Tab: Knowledge -->
  <div id="tab-knowledge" class="tab-content hidden">
    <div class="space-y-5">
      <div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-dark-700 bg-gray-50 dark:bg-dark-900/50">
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Maklumat Produk & Koperasi</h3>
          <p class="mt-0.5 text-xs text-gray-500 dark:text-dark-400">AI akan rujuk maklumat ini untuk menjawab soalan dan mempertahankan koperasi.</p>
        </div>
        <div class="p-6">
          <textarea name="ai_product_info" rows="6" class="w-full px-3.5 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow"><%= settings.ai_product_info || defaults.ai_product_info %></textarea>
          <p class="mt-1.5 text-xs text-gray-400 dark:text-dark-500">Masukkan semua maklumat tentang produk, syarat kelayakan, rakan kerjasama, dan maklumat koperasi. AI akan guna ini untuk semua balasan.</p>
        </div>
      </div>

      <div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-dark-700 bg-gray-50 dark:bg-dark-900/50">
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Arahan Tambahan</h3>
          <p class="mt-0.5 text-xs text-gray-500 dark:text-dark-400">Arahan khas untuk mengawal cara AI berinteraksi. Boleh kosong.</p>
        </div>
        <div class="p-6">
          <textarea name="ai_custom_instructions" rows="4" placeholder="contoh: Jangan tanya lebih dari 2 soalan dalam satu mesej." class="w-full px-3.5 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow"><%= settings.ai_custom_instructions || '' %></textarea>
        </div>
      </div>
    </div>
  </div>

  <!-- Tab: Messages -->
  <div id="tab-messages" class="tab-content hidden">

    <div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-dark-700 bg-gray-50 dark:bg-dark-900/50">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Template Mesej</h3>
        <p class="mt-0.5 text-xs text-gray-500 dark:text-dark-400">Tetapkan mesej balasan AI. Pilih 📋 Tepat (salin tepat) atau 🤖 AI (sesuaikan gaya) untuk setiap mesej.</p>
      </div>
      <div class="p-6 space-y-5">

        <!-- Greeting -->
        <div>
          <div class="flex items-center justify-between mb-1.5">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-blue-500"></span>
              <label class="text-sm font-medium text-gray-700 dark:text-dark-300">Greeting / Mesej Pertama</label>
            </div>
            <div class="flex items-center gap-3">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="hidden" name="ai_auto_greeting" value="off">
                <input type="checkbox" name="ai_auto_greeting" value="on" <%= (settings.ai_auto_greeting || defaults.ai_auto_greeting) === 'on' ? 'checked' : '' %> class="sr-only peer">
                <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary-300 dark:peer-focus:ring-primary-800 rounded-full peer dark:bg-dark-600 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary-600"></div>
                <span class="text-xs font-medium text-gray-500 dark:text-dark-400">Auto Balas</span>
              </label>
              <div class="flex items-center gap-1 bg-gray-100 dark:bg-dark-700 rounded-lg p-0.5">
                <label class="cursor-pointer">
                  <input type="radio" name="ai_greeting_mode" value="exact" <%= (settings.ai_greeting_mode || 'ai_generated') === 'exact' ? 'checked' : '' %> class="peer hidden">
                  <span class="peer-checked:bg-white dark:peer-checked:bg-dark-600 peer-checked:shadow-sm px-2 py-0.5 rounded-md text-xs font-medium text-gray-500 dark:text-dark-400 peer-checked:text-gray-900 dark:peer-checked:text-white transition-all">📋 Tepat</span>
                </label>
                <label class="cursor-pointer">
                  <input type="radio" name="ai_greeting_mode" value="ai_generated" <%= (settings.ai_greeting_mode || 'ai_generated') === 'ai_generated' ? 'checked' : '' %> class="peer hidden">
                  <span class="peer-checked:bg-white dark:peer-checked:bg-dark-600 peer-checked:shadow-sm px-2 py-0.5 rounded-md text-xs font-medium text-gray-500 dark:text-dark-400 peer-checked:text-gray-900 dark:peer-checked:text-white transition-all">🤖 AI</span>
                </label>
              </div>
            </div>
          </div>
          <textarea name="ai_greeting_message" rows="3" class="w-full px-3.5 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow"><%= settings.ai_greeting_message || defaults.ai_greeting_message %></textarea>
          <p class="mt-1 text-xs text-gray-400 dark:text-dark-500">💡 Jika "Auto Balas" aktif, mesej pertama pelanggan akan terus dibalas dengan teks ini tanpa melalui AI.</p>
        </div>

        <!-- Tidak Layak -->
        <div>
          <div class="flex items-center justify-between mb-1.5">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-red-500"></span>
              <label class="text-sm font-medium text-gray-700 dark:text-dark-300">Tidak Layak</label>
            </div>
            <div class="flex items-center gap-1 bg-gray-100 dark:bg-dark-700 rounded-lg p-0.5">
              <label class="cursor-pointer">
                <input type="radio" name="ai_not_eligible_mode" value="exact" <%= (settings.ai_not_eligible_mode || 'ai_generated') === 'exact' ? 'checked' : '' %> class="peer hidden">
                <span class="peer-checked:bg-white dark:peer-checked:bg-dark-600 peer-checked:shadow-sm px-2 py-0.5 rounded-md text-xs font-medium text-gray-500 dark:text-dark-400 peer-checked:text-gray-900 dark:peer-checked:text-white transition-all">📋 Tepat</span>
              </label>
              <label class="cursor-pointer">
                <input type="radio" name="ai_not_eligible_mode" value="ai_generated" <%= (settings.ai_not_eligible_mode || 'ai_generated') === 'ai_generated' ? 'checked' : '' %> class="peer hidden">
                <span class="peer-checked:bg-white dark:peer-checked:bg-dark-600 peer-checked:shadow-sm px-2 py-0.5 rounded-md text-xs font-medium text-gray-500 dark:text-dark-400 peer-checked:text-gray-900 dark:peer-checked:text-white transition-all">🤖 AI</span>
              </label>
            </div>
          </div>
          <textarea name="ai_not_eligible_message" rows="2" class="w-full px-3.5 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow"><%= settings.ai_not_eligible_message || defaults.ai_not_eligible_message %></textarea>
        </div>

        <!-- Eskalasi -->
        <div>
          <div class="flex items-center justify-between mb-1.5">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-amber-500"></span>
              <label class="text-sm font-medium text-gray-700 dark:text-dark-300">Eskalasi ke Pegawai</label>
            </div>
            <div class="flex items-center gap-1 bg-gray-100 dark:bg-dark-700 rounded-lg p-0.5">
              <label class="cursor-pointer">
                <input type="radio" name="ai_escalation_mode" value="exact" <%= (settings.ai_escalation_mode || 'ai_generated') === 'exact' ? 'checked' : '' %> class="peer hidden">
                <span class="peer-checked:bg-white dark:peer-checked:bg-dark-600 peer-checked:shadow-sm px-2 py-0.5 rounded-md text-xs font-medium text-gray-500 dark:text-dark-400 peer-checked:text-gray-900 dark:peer-checked:text-white transition-all">📋 Tepat</span>
              </label>
              <label class="cursor-pointer">
                <input type="radio" name="ai_escalation_mode" value="ai_generated" <%= (settings.ai_escalation_mode || 'ai_generated') === 'ai_generated' ? 'checked' : '' %> class="peer hidden">
                <span class="peer-checked:bg-white dark:peer-checked:bg-dark-600 peer-checked:shadow-sm px-2 py-0.5 rounded-md text-xs font-medium text-gray-500 dark:text-dark-400 peer-checked:text-gray-900 dark:peer-checked:text-white transition-all">🤖 AI</span>
              </label>
            </div>
          </div>
          <textarea name="ai_escalation_message" rows="4" class="w-full px-3.5 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow"><%= settings.ai_escalation_message || defaults.ai_escalation_message %></textarea>
          <p class="mt-1.5 text-xs text-gray-400 dark:text-dark-500">Placeholder: <code class="bg-gray-100 dark:bg-dark-700 px-1 rounded">{agent_name}</code> <code class="bg-gray-100 dark:bg-dark-700 px-1 rounded">{agent_phone}</code> <code class="bg-gray-100 dark:bg-dark-700 px-1 rounded">{agent_wa_url}</code></p>
        </div>

      </div>
    </div>
  </div>

  <!-- Tab: Escalation -->
  <div id="tab-escalation" class="tab-content hidden">
    <div class="space-y-5">
      <div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-dark-700 bg-gray-50 dark:bg-dark-900/50">
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Trigger Eskalasi</h3>
          <p class="mt-0.5 text-xs text-gray-500 dark:text-dark-400">Tandakan situasi yang perlu dieskalasi kepada pegawai manusia secara automatik.</p>
        </div>
        <div class="p-6">
          <input type="hidden" name="ai_escalation_triggers" id="escalationTriggersInput" value="">
          <% const triggers = (settings.ai_escalation_triggers || defaults.ai_escalation_triggers).split(','); %>
          <div class="space-y-3">
            <div class="p-3 rounded-xl border border-gray-200 dark:border-dark-700">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-sm font-medium text-gray-900 dark:text-white">📄 Dokumen / Slip Gaji Diterima</span>
              </div>
              <div class="flex gap-3">
                <label class="flex-1 cursor-pointer">
                  <input type="radio" name="ai_slip_mode" value="smart_ocr" <%= (settings.ai_slip_mode || 'smart_ocr') === 'smart_ocr' ? 'checked' : '' %> class="peer hidden">
                  <div class="p-2.5 rounded-lg border-2 border-gray-200 dark:border-dark-600 peer-checked:border-primary-500 peer-checked:bg-primary-50 dark:peer-checked:bg-primary-500/10 text-center transition-all">
                    <span class="text-xs font-semibold text-gray-700 dark:text-dark-300">🤖 Smart OCR</span>
                    <p class="text-[10px] text-gray-400 dark:text-dark-500 mt-0.5">Baca slip → AI sahkan</p>
                  </div>
                </label>
                <label class="flex-1 cursor-pointer">
                  <input type="radio" name="ai_slip_mode" value="auto_escalate" <%= (settings.ai_slip_mode || 'smart_ocr') === 'auto_escalate' ? 'checked' : '' %> class="peer hidden">
                  <div class="p-2.5 rounded-lg border-2 border-gray-200 dark:border-dark-600 peer-checked:border-primary-500 peer-checked:bg-primary-50 dark:peer-checked:bg-primary-500/10 text-center transition-all">
                    <span class="text-xs font-semibold text-gray-700 dark:text-dark-300">⚡ Auto Escalate</span>
                    <p class="text-[10px] text-gray-400 dark:text-dark-500 mt-0.5">Terus escalate ke pegawai</p>
                  </div>
                </label>
              </div>
            </div>
          </div>

          <!-- Silence hours -->
          <div class="mt-6 pt-6 border-t border-gray-200 dark:border-dark-700 space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1">Tempoh Senyap AI Selepas Eskalasi (jam)</label>
              <p class="text-xs text-gray-500 dark:text-dark-400 mb-2">AI tidak akan balas mesej baru selepas dieskalasi, sehingga tempoh ini tamat.</p>
              <input type="number" name="ai_silence_hours" value="<%= settings.ai_silence_hours || defaults.ai_silence_hours %>" min="1" max="168" class="w-32 px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent">
              <span class="text-xs text-gray-400 ml-2">jam (1-168)</span>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1">Had Mesej Tidak Berkaitan</label>
              <p class="text-xs text-gray-500 dark:text-dark-400 mb-2">Jika pelanggan hantar mesej tidak berkaitan berturut-turut melebihi had ini, AI akan berhenti balas.</p>
              <input type="number" name="ai_offtopic_limit" value="<%= settings.ai_offtopic_limit || defaults.ai_offtopic_limit %>" min="1" max="20" class="w-32 px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent">
              <span class="text-xs text-gray-400 ml-2">mesej (1-20)</span>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-dark-700 bg-gray-50 dark:bg-dark-900/50">
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white">🛡️ Balasan Kata Negatif</h3>
          <p class="mt-0.5 text-xs text-gray-500 dark:text-dark-400">Apabila pelanggan guna kata negatif (scam, tipu, dll), AI akan balas dengan gambar + caption ini.</p>
        </div>
        <div class="p-6 space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Kata Kunci Negatif</label>
            <input type="text" name="ai_bad_words" value="<%= settings.ai_bad_words || defaults.ai_bad_words %>" class="w-full px-3.5 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow">
            <p class="mt-1 text-xs text-gray-400 dark:text-dark-500">Pisahkan dengan koma. Contoh: scam, tipu, bodoh, penipu</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Gambar Balasan</label>
            <p class="text-xs text-gray-500 dark:text-dark-400 mb-2">Muat naik gambar (contoh: sijil koperasi) yang akan dihantar bersama caption apabila kata negatif dikesan.</p>
            <div class="flex items-center gap-4">
              <label class="cursor-pointer inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-700 dark:text-dark-300 hover:bg-gray-50 dark:hover:bg-dark-600 transition-colors">
                <span>📷 Pilih Gambar</span>
                <input type="file" name="ai_scam_defense_image" accept="image/*" class="hidden" onchange="previewScamImage(this)">
              </label>
              <% if (settings.ai_scam_defense_image) { %>
                <img src="<%= settings.ai_scam_defense_image %>" alt="Scam defense" class="w-16 h-16 rounded-lg object-cover border border-gray-200 dark:border-dark-600" id="scamImagePreview">
              <% } else { %>
                <div class="w-16 h-16 rounded-lg border-2 border-dashed border-gray-300 dark:border-dark-600 flex items-center justify-center text-gray-400 text-xs" id="scamImagePreview">Tiada</div>
              <% } %>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="text-sm font-medium text-gray-700 dark:text-dark-300">Caption Gambar</label>
              <div class="flex items-center gap-1 bg-gray-100 dark:bg-dark-700 rounded-lg p-0.5">
                <label class="cursor-pointer">
                  <input type="radio" name="ai_scam_defense_mode" value="exact" <%= (settings.ai_scam_defense_mode || 'ai_generated') === 'exact' ? 'checked' : '' %> class="peer hidden">
                  <span class="peer-checked:bg-white dark:peer-checked:bg-dark-600 peer-checked:shadow-sm px-2 py-0.5 rounded-md text-xs font-medium text-gray-500 dark:text-dark-400 peer-checked:text-gray-900 dark:peer-checked:text-white transition-all">📋 Tepat</span>
                </label>
                <label class="cursor-pointer">
                  <input type="radio" name="ai_scam_defense_mode" value="ai_generated" <%= (settings.ai_scam_defense_mode || 'ai_generated') === 'ai_generated' ? 'checked' : '' %> class="peer hidden">
                  <span class="peer-checked:bg-white dark:peer-checked:bg-dark-600 peer-checked:shadow-sm px-2 py-0.5 rounded-md text-xs font-medium text-gray-500 dark:text-dark-400 peer-checked:text-gray-900 dark:peer-checked:text-white transition-all">🤖 AI</span>
                </label>
              </div>
            </div>
            <textarea name="ai_scam_defense_caption" rows="3" class="w-full px-3.5 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow"><%= settings.ai_scam_defense_caption || 'Kami adalah koperasi berdaftar di bawah Suruhanjaya Koperasi Malaysia (SKM). Sila rujuk sijil pendaftaran kami.' %></textarea>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-dark-700 bg-gray-50 dark:bg-dark-900/50">
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Kata Kunci Pesaing / Suspek</h3>
          <p class="mt-0.5 text-xs text-gray-500 dark:text-dark-400">Jika pelanggan sebut kata kunci ini, AI akan lebih berhati-hati dan tidak dedahkan maklumat dalaman.</p>
        </div>
        <div class="p-6">
          <input type="text" name="ai_competitor_keywords" value="<%= settings.ai_competitor_keywords || '' %>" placeholder="nama pesaing 1, nama pesaing 2" class="w-full px-3.5 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow">
          <p class="mt-1.5 text-xs text-gray-400 dark:text-dark-500">Pisahkan dengan koma. Kosongkan jika tidak perlu.</p>
        </div>
      </div>

    </div>
  </div>

  <!-- Tab: Manual Reply -->
  <div id="tab-manual" class="tab-content hidden">
    <div class="bg-white dark:bg-dark-800 rounded-2xl border border-amber-200 dark:border-amber-500/30 shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-amber-200 dark:border-amber-500/30 bg-amber-50 dark:bg-amber-500/5">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          <h3 class="text-sm font-semibold text-amber-800 dark:text-amber-300">Kata Kunci / Ayat Manual Reply</h3>
        </div>
        <p class="mt-0.5 text-xs text-amber-600 dark:text-amber-400/70">Jika mesej pelanggan mengandungi mana-mana kata kunci atau ayat di bawah, AI akan <strong>SENYAP sepenuhnya</strong> dan chat ditandakan untuk balasan manual oleh pegawai. Notifikasi akan muncul di dashboard.</p>
      </div>
      <div class="p-6">
        <input type="hidden" name="ai_manual_keywords" id="manualKeywordsInput" value="">

        <!-- Tambah button -->
        <div class="flex justify-end mb-4">
          <button type="button" onclick="showKeywordModal()" class="px-4 py-2.5 rounded-xl bg-amber-500 text-white text-sm font-medium hover:bg-amber-600 transition-colors flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Tambah
          </button>
        </div>

        <!-- Keywords table -->
        <div class="border border-gray-200 dark:border-dark-600 rounded-xl overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-50 dark:bg-dark-700/50">
                <th class="text-left px-4 py-2.5 font-semibold text-gray-600 dark:text-dark-400 w-12">#</th>
                <th class="text-left px-4 py-2.5 font-semibold text-gray-600 dark:text-dark-400">Kata Kunci / Ayat</th>
                <th class="text-right px-4 py-2.5 font-semibold text-gray-600 dark:text-dark-400 w-20">Padam</th>
              </tr>
            </thead>
            <tbody id="keywordsTableBody" class="divide-y divide-gray-200 dark:divide-dark-600">
            </tbody>
          </table>
          <div id="emptyKeywords" class="hidden px-4 py-8 text-center text-sm text-gray-400 dark:text-dark-500">
            Tiada kata kunci. Klik "Tambah" untuk mula.
          </div>
        </div>

        <p class="mt-3 text-xs text-gray-400 dark:text-dark-500">💡 Tip: Boleh masukkan kata kunci pendek ("urgent") atau ayat panjang ("saya nak buat bayaran manual"). Padanan adalah case-insensitive.</p>
      </div>
    </div>
  </div>

<!-- Add Keywords Modal -->
<div id="keywordModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
  <div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-xl p-6 w-full max-w-lg mx-4">
    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1">Tambah Kata Kunci</h3>
    <p class="text-xs text-gray-500 dark:text-dark-400 mb-4">Masukkan satu kata kunci atau ayat per baris. Semua baris akan ditambah sekaligus.</p>
    <textarea id="bulkKeywordsInput" rows="8" class="w-full px-3.5 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-amber-500 focus:border-transparent font-mono" placeholder="urgent&#10;saya nak bayar&#10;complaint bayaran&#10;masalah besar dengan akaun"></textarea>
    <div class="flex justify-end gap-3 mt-4">
      <button type="button" onclick="closeKeywordModal()" class="px-4 py-2 rounded-xl border border-gray-300 dark:border-dark-600 text-sm font-medium text-gray-700 dark:text-dark-300 hover:bg-gray-100 dark:hover:bg-dark-700">Batal</button>
      <button type="button" onclick="addBulkKeywords()" class="px-4 py-2 rounded-xl bg-amber-500 text-white text-sm font-medium hover:bg-amber-600">Tambah Semua</button>
    </div>
  </div>
</div>

  <!-- Save Button (always visible) -->
  <div class="mt-6 flex items-center justify-between">
    <p class="text-xs text-gray-400 dark:text-dark-500">Perubahan akan berkuat kuasa serta-merta selepas disimpan.</p>
    <button type="submit" class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl bg-primary-600 text-white text-sm font-medium hover:bg-primary-700 shadow-lg shadow-primary-500/25 transition-all">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      Simpan Perubahan
    </button>
  </div>
</form>

<style>
  .tab-btn { color: rgb(107 114 128); }
  .tab-btn.active { background: white; color: rgb(79 70 229); box-shadow: 0 1px 3px rgba(0,0,0,.1); }
  .dark .tab-btn.active { background: rgb(30 30 40); color: rgb(129 140 248); }
</style>

<script>
// Tab switching
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.remove('hidden');
  });
});

// ─── MANUAL KEYWORDS TABLE ───
let manualKeywords = [];

// Load existing keywords (stored as newline-separated)
const existingKeywords = <%- JSON.stringify(settings.ai_manual_keywords || '') %>;
if (existingKeywords.trim()) {
  // Support both comma-separated (old format) and newline-separated (new format)
  manualKeywords = existingKeywords.split(/[\n,]/).map(k => k.trim()).filter(Boolean);
}

function renderKeywordsTable() {
  const tbody = document.getElementById('keywordsTableBody');
  const empty = document.getElementById('emptyKeywords');

  if (manualKeywords.length === 0) {
    tbody.innerHTML = '';
    empty.classList.remove('hidden');
    return;
  }

  empty.classList.add('hidden');
  tbody.innerHTML = manualKeywords.map((kw, i) => `
    <tr class="hover:bg-gray-50 dark:hover:bg-dark-700/30 transition-colors">
      <td class="px-4 py-2.5 text-gray-400 dark:text-dark-500">${i + 1}</td>
      <td class="px-4 py-2.5 text-gray-900 dark:text-white">${kw}</td>
      <td class="px-4 py-2.5 text-right">
        <button type="button" onclick="removeKeyword(${i})" class="p-1 rounded text-gray-400 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-500/10 transition-colors" title="Padam">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        </button>
      </td>
    </tr>
  `).join('');
}

function showKeywordModal() {
  document.getElementById('bulkKeywordsInput').value = '';
  document.getElementById('keywordModal').classList.remove('hidden');
  document.getElementById('keywordModal').classList.add('flex');
  setTimeout(() => document.getElementById('bulkKeywordsInput').focus(), 100);
}

function closeKeywordModal() {
  document.getElementById('keywordModal').classList.add('hidden');
  document.getElementById('keywordModal').classList.remove('flex');
}

function addBulkKeywords() {
  const input = document.getElementById('bulkKeywordsInput').value;
  const lines = input.split('\n').map(l => l.trim()).filter(Boolean);
  let added = 0;
  lines.forEach(line => {
    if (!manualKeywords.some(k => k.toLowerCase() === line.toLowerCase())) {
      manualKeywords.push(line);
      added++;
    }
  });
  closeKeywordModal();
  renderKeywordsTable();
  if (added > 0) alert(`${added} kata kunci ditambah.`);
  else if (lines.length > 0) alert('Semua kata kunci sudah wujud.');
}

function removeKeyword(index) {
  manualKeywords.splice(index, 1);
  renderKeywordsTable();
}

// Initial render
renderKeywordsTable();

// Preview scam defense image
function previewScamImage(input) {
  const file = input.files[0];
  if (!file) return;
  const preview = document.getElementById('scamImagePreview');
  const reader = new FileReader();
  reader.onload = (e) => {
    if (preview.tagName === 'IMG') {
      preview.src = e.target.result;
    } else {
      const img = document.createElement('img');
      img.src = e.target.result;
      img.className = 'w-16 h-16 rounded-lg object-cover border border-gray-200 dark:border-dark-600';
      img.id = 'scamImagePreview';
      preview.replaceWith(img);
    }
  };
  reader.readAsDataURL(file);
}

// Form submit
document.getElementById('aiSettingsForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  // Sync escalation triggers
  const checked = [...document.querySelectorAll('.escalation-cb:checked')].map(cb => cb.value);
  document.getElementById('escalationTriggersInput').value = checked.join(',');
  // Sync manual keywords (newline-separated)
  document.getElementById('manualKeywordsInput').value = manualKeywords.join('\n');
  // Use FormData for file uploads
  const formData = new FormData(e.target);
  try {
    const res = await fetch('/dashboard/ai-settings', {
      method: 'POST',
      body: formData,
    });
    const result = await res.json();
    if (result.success) { alert('Perubahan berjaya disimpan!'); location.reload(); }
    else alert(result.error || 'Gagal menyimpan');
  } catch (err) { alert('Error saving'); }
});
</script>

