<% locals.pageTitle = 'Pegawai Bertugas' %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Pegawai Bertugas</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-dark-400">Urus senarai pegawai yang menerima kes eskalasi. Kes diagihkan secara bergilir (round-robin).</p>
  </div>
  <div class="flex gap-2">
    <button onclick="resetCounts()" class="px-4 py-2 rounded-xl border border-gray-300 dark:border-dark-600 text-sm font-medium text-gray-700 dark:text-dark-300 hover:bg-gray-100 dark:hover:bg-dark-800 transition-colors">
      Reset Kiraan
    </button>
    <button onclick="showAddModal()" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-primary-600 text-white text-sm font-medium hover:bg-primary-700 shadow-lg shadow-primary-500/25 transition-all">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Tambah Pegawai
    </button>
  </div>
</div>

<!-- Agent List -->
<div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200 dark:border-dark-700 bg-gray-50 dark:bg-dark-900/50">
        <th class="text-left px-6 py-3 font-semibold text-gray-600 dark:text-dark-400">Nama</th>
        <th class="text-left px-6 py-3 font-semibold text-gray-600 dark:text-dark-400">No. Telefon</th>
        <th class="text-center px-6 py-3 font-semibold text-gray-600 dark:text-dark-400">Kes Diterima</th>
        <th class="text-center px-6 py-3 font-semibold text-gray-600 dark:text-dark-400">Status</th>
        <th class="text-right px-6 py-3 font-semibold text-gray-600 dark:text-dark-400">Tindakan</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 dark:divide-dark-700">
      <% if (agents.length === 0) { %>
        <tr>
          <td colspan="5" class="px-6 py-12 text-center text-gray-400 dark:text-dark-500">
            Tiada pegawai bertugas. Klik "Tambah Pegawai" untuk mula.
          </td>
        </tr>
      <% } %>
      <% agents.forEach(agent => { %>
        <tr id="agent-<%= agent.id %>" class="hover:bg-gray-50 dark:hover:bg-dark-700/50 transition-colors">
          <td class="px-6 py-4">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center text-white text-xs font-bold">
                <%= agent.name.charAt(0).toUpperCase() %>
              </div>
              <span class="font-medium text-gray-900 dark:text-white"><%= agent.name %></span>
            </div>
          </td>
          <td class="px-6 py-4 text-gray-600 dark:text-dark-300"><%= agent.phone %></td>
          <td class="px-6 py-4 text-center">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400">
              <%= agent.assignmentCount %>
            </span>
          </td>
          <td class="px-6 py-4 text-center">
            <button onclick="toggleAgent(<%= agent.id %>)" class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium transition-colors cursor-pointer
              <%= agent.active ? 'bg-emerald-100 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 hover:bg-emerald-200' : 'bg-gray-100 dark:bg-dark-700 text-gray-500 dark:text-dark-400 hover:bg-gray-200' %>">
              <span class="w-1.5 h-1.5 rounded-full <%= agent.active ? 'bg-emerald-500' : 'bg-gray-400' %>"></span>
              <%= agent.active ? 'Aktif' : 'Tidak Aktif' %>
            </button>
          </td>
          <td class="px-6 py-4 text-right">
            <div class="flex items-center justify-end gap-2">
              <button onclick="editAgent(<%= agent.id %>, '<%= agent.name %>', '<%= agent.phone %>')" class="p-1.5 rounded-lg text-gray-400 hover:text-primary-600 hover:bg-primary-50 dark:hover:bg-primary-500/10 transition-colors" title="Edit">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              </button>
              <button onclick="deleteAgent(<%= agent.id %>)" class="p-1.5 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-500/10 transition-colors" title="Padam">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </div>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<!-- Add/Edit Modal -->
<div id="agentModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
  <div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-xl p-6 w-full max-w-md mx-4">
    <h3 id="modalTitle" class="text-lg font-bold text-gray-900 dark:text-white mb-4">Tambah Pegawai</h3>
    <form id="agentForm" class="space-y-4">
      <input type="hidden" id="agentId" value="">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Nama</label>
        <input type="text" id="agentName" required class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500" placeholder="contoh: Puan Sarah">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">No. Telefon</label>
        <input type="text" id="agentPhone" required class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500" placeholder="contoh: 011-12345678">
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="closeModal()" class="px-4 py-2 rounded-xl border border-gray-300 dark:border-dark-600 text-sm font-medium text-gray-700 dark:text-dark-300 hover:bg-gray-100 dark:hover:bg-dark-700">Batal</button>
        <button type="submit" class="px-4 py-2 rounded-xl bg-primary-600 text-white text-sm font-medium hover:bg-primary-700">Simpan</button>
      </div>
    </form>
  </div>
</div>

<script>
function showAddModal() {
  document.getElementById('modalTitle').textContent = 'Tambah Pegawai';
  document.getElementById('agentId').value = '';
  document.getElementById('agentName').value = '';
  document.getElementById('agentPhone').value = '';
  document.getElementById('agentModal').classList.remove('hidden');
  document.getElementById('agentModal').classList.add('flex');
}

function editAgent(id, name, phone) {
  document.getElementById('modalTitle').textContent = 'Edit Pegawai';
  document.getElementById('agentId').value = id;
  document.getElementById('agentName').value = name;
  document.getElementById('agentPhone').value = phone;
  document.getElementById('agentModal').classList.remove('hidden');
  document.getElementById('agentModal').classList.add('flex');
}

function closeModal() {
  document.getElementById('agentModal').classList.add('hidden');
  document.getElementById('agentModal').classList.remove('flex');
}

document.getElementById('agentForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const id = document.getElementById('agentId').value;
  const name = document.getElementById('agentName').value;
  const phone = document.getElementById('agentPhone').value;

  const url = id ? `/dashboard/duty-agents/${id}` : '/dashboard/duty-agents';
  const method = id ? 'PUT' : 'POST';

  try {
    const res = await fetch(url, {
      method, headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, phone }),
    });
    const result = await res.json();
    if (result.success) location.reload();
    else alert(result.error || 'Gagal');
  } catch (err) { alert('Error'); }
});

async function toggleAgent(id) {
  try {
    const res = await fetch(`/dashboard/duty-agents/${id}/toggle`, { method: 'POST' });
    const result = await res.json();
    if (result.success) location.reload();
  } catch (err) { alert('Error'); }
}

async function deleteAgent(id) {
  if (!confirm('Padam pegawai ini?')) return;
  try {
    const res = await fetch(`/dashboard/duty-agents/${id}`, { method: 'DELETE' });
    const result = await res.json();
    if (result.success) location.reload();
  } catch (err) { alert('Error'); }
}

async function resetCounts() {
  if (!confirm('Reset semua kiraan kes kepada 0?')) return;
  try {
    const res = await fetch('/dashboard/duty-agents/reset', { method: 'POST' });
    const result = await res.json();
    if (result.success) location.reload();
  } catch (err) { alert('Error'); }
}
</script>
