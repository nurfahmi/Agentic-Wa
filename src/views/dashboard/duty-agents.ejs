<% locals.pageTitle = 'Pegawai Bertugas' %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Pegawai Bertugas</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-dark-400">Urus senarai pegawai dan tier. Kes diagihkan berdasarkan tier (weighted round-robin).</p>
  </div>
  <div class="flex gap-2">
    <button onclick="resetCounts()" class="px-4 py-2 rounded-xl border border-gray-300 dark:border-dark-600 text-sm font-medium text-gray-700 dark:text-dark-300 hover:bg-gray-100 dark:hover:bg-dark-800 transition-colors">
      Reset Kiraan
    </button>
    <button onclick="showAddModal()" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-primary-600 text-white text-sm font-medium hover:bg-primary-700 shadow-lg shadow-primary-500/25 transition-all">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Tambah Pegawai
    </button>
  </div>
</div>

<!-- Tier Management -->
<div class="mb-6 bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-sm p-5">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h2 class="text-lg font-bold text-gray-900 dark:text-white">Tetapan Tier</h2>
      <p class="text-xs text-gray-500 dark:text-dark-400 mt-0.5">Berat tier menentukan bilangan kes dalam satu pusingan. Contoh: Berat 3 = dapat 3 kes sebelum pusingan seterusnya.</p>
    </div>
    <button onclick="showTierModal()" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-purple-600 text-white text-xs font-medium hover:bg-purple-700 transition-colors">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Tambah Tier
    </button>
  </div>
  <div class="flex flex-wrap gap-3">
    <% if (tiers.length === 0) { %>
      <p class="text-sm text-gray-400 dark:text-dark-500">Tiada tier. Tambah tier untuk aktifkan weighted round-robin.</p>
    <% } %>
    <% tiers.forEach(tier => { %>
      <div class="group relative flex items-center gap-3 px-4 py-3 rounded-xl border border-gray-200 dark:border-dark-600 bg-gray-50 dark:bg-dark-700/50 hover:border-purple-300 dark:hover:border-purple-500/50 transition-colors">
        <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-gradient-to-br from-purple-400 to-purple-600 text-white text-sm font-bold">
          <%= tier.weight %>
        </div>
        <div>
          <div class="text-sm font-semibold text-gray-900 dark:text-white"><%= tier.name %></div>
          <div class="text-xs text-gray-500 dark:text-dark-400"><%= tier._count.agents %> pegawai · Berat: <%= tier.weight %></div>
        </div>
        <div class="flex items-center gap-1 ml-3 opacity-0 group-hover:opacity-100 transition-opacity">
          <button onclick="editTier(<%= tier.id %>, '<%= tier.name %>', <%= tier.weight %>)" class="p-1 rounded text-gray-400 hover:text-purple-600 transition-colors" title="Edit">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          </button>
          <button onclick="deleteTier(<%= tier.id %>, '<%= tier.name %>')" class="p-1 rounded text-gray-400 hover:text-red-600 transition-colors" title="Padam">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          </button>
        </div>
      </div>
    <% }); %>
  </div>
</div>

<!-- Agent List -->
<div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200 dark:border-dark-700 bg-gray-50 dark:bg-dark-900/50">
        <th class="text-left px-6 py-3 font-semibold text-gray-600 dark:text-dark-400">Nama</th>
        <th class="text-left px-6 py-3 font-semibold text-gray-600 dark:text-dark-400">No. Telefon</th>
        <th class="text-center px-6 py-3 font-semibold text-gray-600 dark:text-dark-400">Tier</th>
        <th class="text-center px-6 py-3 font-semibold text-gray-600 dark:text-dark-400">Syif</th>
        <th class="text-center px-6 py-3 font-semibold text-gray-600 dark:text-dark-400">Hari Ini</th>
        <th class="text-center px-6 py-3 font-semibold text-gray-600 dark:text-dark-400">Jumlah</th>
        <th class="text-center px-6 py-3 font-semibold text-gray-600 dark:text-dark-400">Status</th>
        <th class="text-right px-6 py-3 font-semibold text-gray-600 dark:text-dark-400">Tindakan</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 dark:divide-dark-700">
      <% if (agents.length === 0) { %>
        <tr>
          <td colspan="8" class="px-6 py-12 text-center text-gray-400 dark:text-dark-500">
            Tiada pegawai bertugas. Klik "Tambah Pegawai" untuk mula.
          </td>
        </tr>
      <% } %>
      <% agents.forEach(agent => { %>
        <tr id="agent-<%= agent.id %>" class="hover:bg-gray-50 dark:hover:bg-dark-700/50 transition-colors">
          <td class="px-6 py-4">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center text-white text-xs font-bold">
                <%= agent.name.charAt(0).toUpperCase() %>
              </div>
              <span class="font-medium text-gray-900 dark:text-white"><%= agent.name %></span>
            </div>
          </td>
          <td class="px-6 py-4 text-gray-600 dark:text-dark-300"><%= agent.phone %></td>
          <td class="px-6 py-4 text-center">
            <% if (agent.tier) { %>
              <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 dark:bg-purple-500/10 text-purple-700 dark:text-purple-400">
                <span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>
                <%= agent.tier.name %> (<%= agent.tier.weight %>x)
              </span>
            <% } else { %>
              <span class="text-xs text-gray-400 dark:text-dark-500">Tiada (1x)</span>
            <% } %>
          </td>
          <td class="px-6 py-4 text-center">
            <% if (agent.shiftStart && agent.shiftEnd) { %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-sky-100 dark:bg-sky-500/10 text-sky-700 dark:text-sky-400">
                <%= agent.shiftStart %> - <%= agent.shiftEnd %>
              </span>
            <% } else { %>
              <span class="text-xs text-gray-400 dark:text-dark-500">24 jam</span>
            <% } %>
          </td>
          <td class="px-6 py-4 text-center">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 dark:bg-amber-500/10 text-amber-700 dark:text-amber-400">
              <%= agent.todayCount %>
            </span>
          </td>
          <td class="px-6 py-4 text-center">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400">
              <%= agent.assignmentCount %>
            </span>
          </td>
          <td class="px-6 py-4 text-center">
            <button onclick="toggleAgent(<%= agent.id %>)" class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium transition-colors cursor-pointer
              <%= agent.active ? 'bg-emerald-100 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 hover:bg-emerald-200' : 'bg-gray-100 dark:bg-dark-700 text-gray-500 dark:text-dark-400 hover:bg-gray-200' %>">
              <span class="w-1.5 h-1.5 rounded-full <%= agent.active ? 'bg-emerald-500' : 'bg-gray-400' %>"></span>
              <%= agent.active ? 'Aktif' : 'Tidak Aktif' %>
            </button>
          </td>
          <td class="px-6 py-4 text-right">
            <div class="flex items-center justify-end gap-2">
              <button onclick="editAgent(<%= agent.id %>, '<%= agent.name %>', '<%= agent.phone %>', '<%= agent.shiftStart || '' %>', '<%= agent.shiftEnd || '' %>', '<%= agent.tierId || '' %>')" class="p-1.5 rounded-lg text-gray-400 hover:text-primary-600 hover:bg-primary-50 dark:hover:bg-primary-500/10 transition-colors" title="Edit">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              </button>
              <button onclick="deleteAgent(<%= agent.id %>)" class="p-1.5 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-500/10 transition-colors" title="Padam">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </div>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<!-- Add/Edit Agent Modal -->
<div id="agentModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
  <div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-xl p-6 w-full max-w-md mx-4">
    <h3 id="modalTitle" class="text-lg font-bold text-gray-900 dark:text-white mb-4">Tambah Pegawai</h3>
    <form id="agentForm" class="space-y-4">
      <input type="hidden" id="agentId" value="">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Nama</label>
        <input type="text" id="agentName" required class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500" placeholder="contoh: Puan Sarah">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">No. Telefon</label>
        <input type="text" id="agentPhone" required class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500" placeholder="contoh: 011-12345678">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Tier</label>
        <select id="agentTier" class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500">
          <option value="">Tiada tier (berat 1x)</option>
          <% tiers.forEach(tier => { %>
            <option value="<%= tier.id %>"><%= tier.name %> (berat: <%= tier.weight %>x)</option>
          <% }); %>
        </select>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Mula Syif</label>
          <input type="time" id="agentShiftStart" class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Tamat Syif</label>
          <input type="time" id="agentShiftEnd" class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500">
        </div>
      </div>
      <p class="text-xs text-gray-400 dark:text-dark-500 -mt-2">Kosongkan jika pegawai tersedia 24 jam.</p>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="closeModal()" class="px-4 py-2 rounded-xl border border-gray-300 dark:border-dark-600 text-sm font-medium text-gray-700 dark:text-dark-300 hover:bg-gray-100 dark:hover:bg-dark-700">Batal</button>
        <button type="submit" class="px-4 py-2 rounded-xl bg-primary-600 text-white text-sm font-medium hover:bg-primary-700">Simpan</button>
      </div>
    </form>
  </div>
</div>

<!-- Add/Edit Tier Modal -->
<div id="tierModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
  <div class="bg-white dark:bg-dark-800 rounded-2xl border border-gray-200 dark:border-dark-700 shadow-xl p-6 w-full max-w-sm mx-4">
    <h3 id="tierModalTitle" class="text-lg font-bold text-gray-900 dark:text-white mb-4">Tambah Tier</h3>
    <form id="tierForm" class="space-y-4">
      <input type="hidden" id="tierId" value="">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Nama Tier</label>
        <input type="text" id="tierName" required class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500" placeholder="contoh: Pro">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-dark-300 mb-1">Berat (bilangan kes per pusingan)</label>
        <input type="number" id="tierWeight" required min="1" max="20" class="w-full px-3 py-2.5 rounded-xl border border-gray-300 dark:border-dark-600 bg-white dark:bg-dark-700 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500" placeholder="contoh: 3">
        <p class="text-xs text-gray-400 dark:text-dark-500 mt-1">Pegawai dengan berat 3 akan dapat 3 kes sebelum pusingan even bermula.</p>
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="closeTierModal()" class="px-4 py-2 rounded-xl border border-gray-300 dark:border-dark-600 text-sm font-medium text-gray-700 dark:text-dark-300 hover:bg-gray-100 dark:hover:bg-dark-700">Batal</button>
        <button type="submit" class="px-4 py-2 rounded-xl bg-purple-600 text-white text-sm font-medium hover:bg-purple-700">Simpan</button>
      </div>
    </form>
  </div>
</div>

<script>
// ─── AGENT MODAL ───
function showAddModal() {
  document.getElementById('modalTitle').textContent = 'Tambah Pegawai';
  document.getElementById('agentId').value = '';
  document.getElementById('agentName').value = '';
  document.getElementById('agentPhone').value = '';
  document.getElementById('agentTier').value = '';
  document.getElementById('agentShiftStart').value = '';
  document.getElementById('agentShiftEnd').value = '';
  document.getElementById('agentModal').classList.remove('hidden');
  document.getElementById('agentModal').classList.add('flex');
}

function editAgent(id, name, phone, shiftStart, shiftEnd, tierId) {
  document.getElementById('modalTitle').textContent = 'Edit Pegawai';
  document.getElementById('agentId').value = id;
  document.getElementById('agentName').value = name;
  document.getElementById('agentPhone').value = phone;
  document.getElementById('agentTier').value = tierId || '';
  document.getElementById('agentShiftStart').value = shiftStart || '';
  document.getElementById('agentShiftEnd').value = shiftEnd || '';
  document.getElementById('agentModal').classList.remove('hidden');
  document.getElementById('agentModal').classList.add('flex');
}

function closeModal() {
  document.getElementById('agentModal').classList.add('hidden');
  document.getElementById('agentModal').classList.remove('flex');
}

document.getElementById('agentForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const id = document.getElementById('agentId').value;
  const name = document.getElementById('agentName').value;
  const phone = document.getElementById('agentPhone').value;
  const tierId = document.getElementById('agentTier').value;
  const shiftStart = document.getElementById('agentShiftStart').value;
  const shiftEnd = document.getElementById('agentShiftEnd').value;

  const url = id ? `/dashboard/duty-agents/${id}` : '/dashboard/duty-agents';
  const method = id ? 'PUT' : 'POST';

  try {
    const res = await fetch(url, {
      method, headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, phone, tierId, shiftStart, shiftEnd }),
    });
    const result = await res.json();
    if (result.success) location.reload();
    else alert(result.error || 'Gagal');
  } catch (err) { alert('Error'); }
});

// ─── TIER MODAL ───
function showTierModal() {
  document.getElementById('tierModalTitle').textContent = 'Tambah Tier';
  document.getElementById('tierId').value = '';
  document.getElementById('tierName').value = '';
  document.getElementById('tierWeight').value = '';
  document.getElementById('tierModal').classList.remove('hidden');
  document.getElementById('tierModal').classList.add('flex');
}

function editTier(id, name, weight) {
  document.getElementById('tierModalTitle').textContent = 'Edit Tier';
  document.getElementById('tierId').value = id;
  document.getElementById('tierName').value = name;
  document.getElementById('tierWeight').value = weight;
  document.getElementById('tierModal').classList.remove('hidden');
  document.getElementById('tierModal').classList.add('flex');
}

function closeTierModal() {
  document.getElementById('tierModal').classList.add('hidden');
  document.getElementById('tierModal').classList.remove('flex');
}

document.getElementById('tierForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const id = document.getElementById('tierId').value;
  const name = document.getElementById('tierName').value;
  const weight = document.getElementById('tierWeight').value;

  const url = id ? `/dashboard/duty-agents/tiers/${id}` : '/dashboard/duty-agents/tiers';
  const method = id ? 'PUT' : 'POST';

  try {
    const res = await fetch(url, {
      method, headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, weight }),
    });
    const result = await res.json();
    if (result.success) location.reload();
    else alert(result.error || 'Gagal');
  } catch (err) { alert('Error'); }
});

async function deleteTier(id, name) {
  if (!confirm(`Padam tier "${name}"?`)) return;
  try {
    const res = await fetch(`/dashboard/duty-agents/tiers/${id}`, { method: 'DELETE' });
    const result = await res.json();
    if (result.success) location.reload();
    else alert(result.error || 'Gagal');
  } catch (err) { alert('Error'); }
}

// ─── AGENT ACTIONS ───
async function toggleAgent(id) {
  try {
    const res = await fetch(`/dashboard/duty-agents/${id}/toggle`, { method: 'POST' });
    const result = await res.json();
    if (result.success) location.reload();
  } catch (err) { alert('Error'); }
}

async function deleteAgent(id) {
  if (!confirm('Padam pegawai ini?')) return;
  try {
    const res = await fetch(`/dashboard/duty-agents/${id}`, { method: 'DELETE' });
    const result = await res.json();
    if (result.success) location.reload();
  } catch (err) { alert('Error'); }
}

async function resetCounts() {
  if (!confirm('Reset semua kiraan kes kepada 0?')) return;
  try {
    const res = await fetch('/dashboard/duty-agents/reset', { method: 'POST' });
    const result = await res.json();
    if (result.success) location.reload();
  } catch (err) { alert('Error'); }
}
</script>
